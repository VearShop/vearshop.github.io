<style>
/* VEAR SYSTEM ARCHITECTURE 
   BRAND IDENTITY STYLESHEET 
   CORE DESIGNER: HASNAIN
*/
*{box-sizing:border-box;margin:0;padding:0; cursor: none !important;}
html{scroll-behavior:smooth; background: #000;}

body{
    font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
    background: radial-gradient(circle at top, #003a70, #001a33 60%, #000814);
    color: #f2f2f2;
    overflow-x: hidden;
    line-height: 1.6;
    min-height: 100vh;
}

/* --- CUSTOM CURSOR SYSTEM --- */
#cursor {
    width: 20px; height: 20px;
    background: rgba(77, 166, 255, 0.3);
    border: 1px solid #4da6ff;
    border-radius: 50%;
    position: fixed;
    top: -50px; left: -50px;
    pointer-events: none;
    z-index: 10001;
    transition: transform 0.08s ease-out;
    box-shadow: 0 0 15px #4da6ff;
    display: block;
}
#cursor-follower {
    width: 6px; height: 6px;
    background: #fff;
    border-radius: 50%;
    position: fixed;
    top: -50px; left: -50px;
    pointer-events: none;
    z-index: 10002;
    transition: transform 0.02s linear;
    display: block;
}

#particles-js{
    position: fixed;
    width: 100%; height: 100%;
    top: 0; left: 0;
    z-index: -1;
}

/* --- NAVIGATION --- */
.navbar{
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 60px;
    background: rgba(10, 15, 25, 0.7);
    backdrop-filter: blur(15px);
    position: sticky;
    top: 0;
    z-index: 5000;
    border-bottom: 1px solid rgba(77, 166, 255, 0.1);
    transition: all 0.4s ease;
}
.navbar.scrolled{
    padding: 12px 60px;
    background: rgba(0, 8, 20, 0.98);
}
.navbar img{
    height: 45px;
    filter: drop-shadow(0 0 8px #4da6ff);
    animation: logoPulse 4s infinite ease-in-out;
}
@keyframes logoPulse {
    0%, 100% { filter: drop-shadow(0 0 5px #4da6ff); transform: scale(1); }
    50% { filter: drop-shadow(0 0 15px #4da6ff); transform: scale(1.08); }
}
.nav-links a{
    color: #cfe9ff;
    text-decoration: none;
    margin-left: 30px;
    font-size: 13px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    transition: 0.3s;
    position: relative;
}
.nav-links a:hover{ color: #4da6ff; text-shadow: 0 0 10px #4da6ff; }

/* --- HERO SYSTEM --- */
.hero-slider{
    position: relative;
    height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
    margin-bottom: 300px; 
}
.slide{
    position: absolute;
    width: 80%;
    opacity: 0;
    transform: scale(0.9) translateY(20px);
    transition: all 1.5s cubic-bezier(0.23, 1, 0.32, 1);
}
.slide.active{
    opacity: 1;
    transform: scale(1) translateY(0);
}
.slide h1{
    font-size: 84px;
    margin-bottom: 30px;
    color: #fff;
    text-shadow: 0 0 30px rgba(77,166,255,0.6);
    letter-spacing: 15px;
    font-weight: 800;
}
.slide p{
    font-size: 24px;
    color: #9ccfff;
    max-width: 800px;
    margin: 0 auto;
    letter-spacing: 2px;
}

/* --- (ALL YOUR ORIGINAL CSS REMAINS UNCHANGED) --- */
</style>
</head>

